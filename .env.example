# ── Required secrets ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...

# ── OpenAI ────────────────────────────────────────────────────────────
# Defaults match src/config/settings.py; override here to experiment.
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# CHAT_MODEL=gpt-4o-mini

# ── Pinecone ──────────────────────────────────────────────────────────
# PINECONE_INDEX_NAME=fatawa-hybrid
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
# PINECONE_METRIC=cosine

# ── Data ──────────────────────────────────────────────────────────────
# Defaults to ../data (sibling of the repo). Override if the CSV corpora
# live elsewhere. The four folders expected under DATA_ROOT are:
#   Banuri-ExtractedData-Output
#   IslamQA-ExtractedData-Output
#   fatwaqa-ExtractedData-Output
#   urdufatwa-ExtractedData-Output
# DATA_ROOT=/absolute/path/to/data

# ── Retrieval ─────────────────────────────────────────────────────────
# TOP_K=10
# DENSE_WEIGHT=0.7
# SPARSE_WEIGHT=0.3
# CONTEXT_TOKEN_BUDGET=3000
# ANSWER_MAX_TOKENS=512

# ── Ingestion ─────────────────────────────────────────────────────────
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# BATCH_SIZE=100

# ── Islam360-only pipeline (1536-dim; separate Pinecone index) ───────
# Place CSV/JSON (Question + Answer columns) under data/islam-360-fatwa-data/
# Then: python scripts/ingest_islam360.py
# Query: python run_islam360_query.py "your question"
# ISLAM360_DATA_DIR=D:/Hybrid-Fatwa-Retrieval/data/islam-360-fatwa-data
# ISLAM360_PINECONE_INDEX=islam360-fatwa-1536
# ISLAM360_EMBEDDING_MODEL=text-embedding-3-small
# ISLAM360_EMBEDDING_DIMENSIONS=1536
# ISLAM360_RETRIEVAL_CANDIDATES=20
# ISLAM360_RERANK_TOP_K=5
# ISLAM360_MIN_RELEVANCE_SCORE=0.35
